<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <template id="custom_web_login" inherit_id="web.login" name="Custom Login">
        
            <xpath expr="//form" position="inside">
                <t t-set="alignment_of_form" t-value="request.env['ir.config_parameter'].sudo().get_param('advance_login_form.alignment')"></t>
                <span t-attf-class="#{'align_advance_login_form_left' if alignment_of_form == 'left' else 'align_advance_login_form_right' if alignment_of_form == 'right' else 'align_advance_login_form_center'}" separator=" "></span>

            </xpath>
            <xpath expr="//form/input[@type='hidden']" position="before">
                <div class="logos" >
                    <div class="origo">
                        <img src="/advance_login_form/static/src/img/b.jpg" />   
                        
                    </div>
                    <div class="fayzen">
                        <img src="/advance_login_form/static/src/img/a.jpg"  />   
                    </div>
                </div>
            </xpath>




            <xpath expr="//form[@class='oe_login_form']" position="attributes">
                <!-- <attribute name="t-attf-style">background-color: #{request.env['ir.config_parameter'].sudo().get_param('advance_login_form.background_color') or ''}; color: #{request.env['ir.config_parameter'].sudo().get_param('advance_login_form.text_color') or ''};</attribute> -->
               <!-- set height of login form to 90vh and make它 responsive -->
                <!-- <attribute name="t-attf-style">height: 54vh;background-color: rgba(0, 0, 0, 0.3);  margin-top: 0vh; box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);</attribute> -->
            </xpath>
            
            
            <!-- Username label -->
            <xpath expr="//div[@class='mb-3 field-login']/label[@for='login']" position="attributes">
                <attribute name="class">form-label fw-bold</attribute>
                <attribute name="style">font-size:15px;
                    font-family:'Arial', sans-serif;
                    letter-spacing:0.5px;
                    color:#2a3e55;
                </attribute>
                <attribute name="t-esc">"Username"</attribute>
            </xpath>




            <!-- Username input -->
<xpath expr="//div[@class='mb-3 field-login']/input[@name='login']" position="attributes">
    <attribute name="placeholder">Enter Username</attribute>
    <attribute name="t-attf-style">
        width:100%;              /* full width */
        font-size:16px;          /* larger font */
        font-family: 'Arial', sans-serif;  /* better font */
        font-weight:500;
        border-radius:12px;      /* slightly bigger rounding */
        border:2px solid #{request.env['ir.config_parameter'].sudo().get_param('advance_login_form.text_color') or '#ccc'} !important;
        padding:14px 12px;       /* more padding for bigger input */
        transition:0.3s;
        color: #333;
        letter-spacing:0.5px;
    </attribute>
</xpath>

<!-- Password label -->
<xpath expr="//div[@class='mb-3'][2]/label[@for='password']" position="attributes">
    <attribute name="class">form-label fw-bold</attribute>
    <attribute name="style">
        font-size:15px;
        font-family:'Arial', sans-serif;
        letter-spacing:0.5px;
        color:#2a3e55;
    </attribute>
    <attribute name="t-esc">"Password"</attribute>
</xpath>

<!-- Password input -->
<xpath expr="//input[@name='password']" position="attributes">
    <attribute name="placeholder">Enter Password</attribute>
    <attribute name="t-attf-style">
        width:100%;
        font-size:16px;
        font-family: 'Arial', sans-serif;
        font-weight:500;
        border-radius:12px;
        border:2px solid #{request.env['ir.config_parameter'].sudo().get_param('advance_login_form.text_color') or '#ccc'} !important;
        padding:14px 12px;
        transition:0.3s;
        color: #333;
        letter-spacing:0.5px;
    </attribute>
</xpath>

<!-- Login button -->
<xpath expr="//button[@class='btn btn-primary']" position="attributes">
    <attribute name="t-attf-style">
        width:100%;
        font-size:16px;
        font-family:'Arial', sans-serif;
        font-weight:600;
        background-color:#2a3e55;
        border:0px;
        border-radius:12px;
        padding:14px;
        color:#fff;
        transition:0.3s;
        cursor:pointer;
    </attribute>
    <attribute name="t-attf-onmouseover">
        this.style.transform='translateY(-3px)';
        this.style.boxShadow='0 8px 20px #9d5426';
    </attribute>
    <attribute name="t-attf-onmouseout">
        this.style.transform='translateY(0)';
        this.style.boxShadow='none';
    </attribute>
</xpath>


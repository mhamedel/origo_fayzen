<odoo>
    <data>

        <report
            id="custom_invoice_report_action"
            model="account.move"
            string="Custom Invoice"
            report_type="qweb-pdf"
            name="colis_kg.custom_invoice_report"
            file="colis_kg.custom_invoice_report"
        />


        <record id="custom_invoice_report_action" model="ir.actions.report">
            <field name="name">Custom Invoice</field>
            <field name="model">account.move</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">colis_kg.custom_invoice_report</field>
            <field name="report_file">colis_kg.custom_invoice_report</field>
            <field name="print_report_name">(object._get_report_base_filename())</field>
        </record>

        <template id="custom_invoice_report">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Custom Invoice</h2>
                        <p t-esc="doc.name"/>
                    </div>
                </t>
            </t>
        </template>

    </data>
</odoo>
								text-align: center;
								padding: 8px 6px;
								font-size: 13px;
							}

							.total-box table {
								border-radius: 10px;  /* rounded corners */
								overflow: hidden;     /* ensures inner cells don't overflow the rounded corners */
								border: 2px solid black; /* optional: outer border */
								border-collapse:  collapse; /* ensures borders are collapsed for proper rounding */
							}

							/* TABLE */
							.table-container {
								height: 350px;          /* fixed total table height */
								margin-top: 35px;
								border: 2px solid black;
								border-radius: 70px;
								overflow: hidden;
							}


							table {

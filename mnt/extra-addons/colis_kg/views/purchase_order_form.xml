<?xml version="1.0" encoding="utf-8"?>
<odoo>

		<record id="view_purchase_order_form_inherit_kg" model="ir.ui.view">
			<field name="name">purchase.order.form.inherit.qty_kg</field>
			<field name="model">purchase.order</field>
			<field name="inherit_id" ref="purchase.purchase_order_form"/>
			<field name="arch" type="xml">

				<xpath expr="//field[@name='order_line']/tree/field[@name='product_qty']" position="after">
					<field name="qty_kg" string="Quantity (kg)"/>
				</xpath>

			</field>
		</record>


		<record id="sale_order_line_form_inherit_qty_kg" model="ir.ui.view">
			<field name="name">sale.order.line.form.inherit.qty_kg</field>
			<field name="model">sale.order</field>
			<field name="inherit_id" ref="sale.view_order_form"/>
			<field name="arch" type="xml">
				<xpath expr="//tree/field[@name='product_uom_qty']" position="after">
					<field name="qty_kg" string="Quantity (kg)"/>
				</xpath>
			</field>
		</record>


		<record id="account_move_form_inherit_kg" model="ir.ui.view">
			<field name="name">account.move.form.inherit.qty_kg</field>
			<field name="model">account.move</field>
			<field name="inherit_id" ref="account.view_move_form"/>
			<field name="arch" type="xml">
				<xpath expr="//tree/field[@name='quantity']" position="after">
					<field name="qty_kg" string="Quantity (kg)"/>
				</xpath>
			</field>
		</record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>

		<record id="view_purchase_order_form_inherit_kg" model="ir.ui.view">
			<field name="name">purchase.order.form.inherit.qty_kg</field>
			<field name="model">purchase.order</field>
			<field name="inherit_id" ref="purchase.purchase_order_form"/>
			<field name="arch" type="xml">

				<xpath expr="//field[@name='order_line']/tree/field[@name='product_qty']" position="after">
					<field name="qty_kg" string="Quantity (kg)" required="1"/>
				</xpath>

			</field>
		</record>


		<record id="sale_order_line_form_inherit_qty_kg" model="ir.ui.view">
			<field name="name">sale.order.line.form.inherit.qty_kg</field>
			<field name="model">sale.order</field>
			<field name="inherit_id" ref="sale.view_order_form"/>
			<field name="arch" type="xml">
				<xpath expr="//tree/field[@name='product_uom_qty']" position="after">
					<field name="qty_kg" string="Quantity (kg)" required="1"/>
				</xpath>
			</field>
		</record>


		<record id="account_move_form_inherit_kg" model="ir.ui.view">
			<field name="name">account.move.form.inherit.qty_kg</field>
			<field name="model">account.move</field>
			<field name="inherit_id" ref="account.view_move_form"/>
			<field name="arch" type="xml">
				<xpath expr="//tree/field[@name='quantity']" position="after">
					<field name="qty_kg" string="Quantity (kg)" required="1"/>
				</xpath>
			</field>
		</record>

	<record id="paperformat_invoice_custom" model="report.paperformat">
		<field name="name">Invoice Custom A4</field>
		<field name="default" eval="False"/>
		<field name="format">A4</field>

		<!-- 🔥 THIS IS THE FIX -->
		<field name="margin_top">0</field>
		<field name="margin_bottom">5</field>
		<field name="margin_left">5</field>
		<field name="margin_right">5</field>

		<field name="orientation">Portrait</field>
		<field name="header_line" eval="False"/>
		<field name="header_spacing">0</field>
		<field name="dpi">96</field>
	</record>
	<record id="account.account_invoices" model="ir.actions.report">
		<field name="paperformat_id" ref="paperformat_invoice_custom"/>
	</record>


		


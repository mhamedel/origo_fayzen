								border-right: 2px solid black;
								padding: 8px;
								font-size: 13px;
							}

							.table-container table {
								width: 100%;
								border-collapse: collapse;
								height: 100%;            
								table-layout: fixed;    
							}



							.table-container th,
							.table-container td {
								border-right: 2px solid black;
								text-align: center;       
								vertical-align: middle;  
								font-size: 13px;
								height: 35px;             
								padding: 8px;
							}

							.table-container tbody {
